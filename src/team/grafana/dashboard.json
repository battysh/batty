{
  "__inputs": [
    {
      "name": "DS_BATTY",
      "label": "Batty SQLite",
      "description": "SQLite datasource for Batty telemetry",
      "type": "datasource",
      "pluginId": "frser-sqlite-datasource"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Per-project monitoring dashboard for Batty agent teams",
  "editable": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Session Overview",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "super-light-green", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "h"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT ROUND(MAX(json_extract(payload, '$.uptime_secs')) / 3600.0, 1) as value FROM events WHERE event_type='daemon_heartbeat';",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Uptime (hrs)",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) as value FROM task_cycle WHERE completed_at IS NOT NULL;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Tasks Completed",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) as value FROM task_cycle WHERE completed_at IS NULL AND started_at IS NOT NULL;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "In Progress",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "light-blue", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "light-blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) as value FROM events WHERE event_type='agent_spawned';",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Engineers Active",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT ROUND(CAST(SUM(tasks_completed) AS REAL) / MAX(1, COUNT(*)), 1) as value FROM daily_stats WHERE tasks_completed > 0;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Throughput (tasks/day)",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) as value FROM events;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Total Events",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "Pipeline Health",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Created" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Completed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Started" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 20,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT CAST((julianday(date) - 2440587.5) * 86400000 AS INTEGER) as time, tasks_created as 'Created', tasks_completed as 'Completed', tasks_started as 'Started' FROM daily_stats WHERE tasks_created > 0 OR tasks_completed > 0 ORDER BY date;",
          "queryType": "table",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "title": "Daily Task Flow",
      "type": "timeseries"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 21,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT (timestamp / 3600) * 3600 * 1000 as time, COUNT(*) as events FROM events GROUP BY timestamp / 3600 ORDER BY time;",
          "queryType": "table",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "title": "Events Per Hour",
      "type": "timeseries"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 98 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 14 },
      "id": 22,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT ROUND(100.0 * (1.0 - CAST((SELECT COUNT(*) FROM events WHERE event_type='delivery_failed') AS REAL) / MAX(1, (SELECT COUNT(*) FROM events WHERE event_type='message_routed'))), 1) as value;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Delivery Success Rate",
      "type": "gauge"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "max": 50,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 14 },
      "id": 23,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT ROUND(CAST((SELECT COUNT(*) FROM events WHERE event_type='message_routed') AS REAL) / MAX(1, (SELECT COUNT(*) FROM events WHERE event_type='task_assigned')), 1) as value;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Messages per Task",
      "type": "gauge"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 40 }
            ]
          },
          "unit": "%"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 14 },
      "id": 24,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT ROUND(100.0 * (SELECT COUNT(*) FROM task_flow WHERE action='release') / NULLIF((SELECT COUNT(*) FROM task_flow WHERE action='claim'), 0), 1) as 'Rework %';",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Rework Rate",
      "type": "gauge"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 14 },
      "id": 25,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) as 'Blocked Events' FROM task_flow WHERE action = 'block';",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Blocked Tasks",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 300,
      "title": "Agent Performance",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Avg Hours" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Tasks Done" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 21 },
      "id": 30,
      "options": { "orientation": "horizontal" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT claimed_by as 'Engineer', ROUND(AVG(cycle_time_hours),1) as 'Avg Hours', COUNT(*) as 'Tasks Done' FROM task_cycle WHERE completed_at IS NOT NULL AND claimed_by != '' GROUP BY claimed_by ORDER BY COUNT(*) DESC;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Cycle Time by Engineer",
      "type": "barchart"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 21 },
      "id": 31,
      "options": { "bucketSize": 0.5 },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT cycle_time_hours as 'Cycle Time (h)' FROM task_cycle WHERE completed_at IS NOT NULL AND cycle_time_hours IS NOT NULL;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Cycle Time Distribution",
      "type": "histogram"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 400,
      "title": "Delivery & Communication",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 31 },
      "id": 40,
      "options": { "orientation": "horizontal" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT json_extract(payload, '$.from') || ' -> ' || json_extract(payload, '$.to') as route, COUNT(*) as messages FROM events WHERE event_type='message_routed' GROUP BY route ORDER BY messages DESC LIMIT 10;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Top Message Routes",
      "type": "barchart"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 31 },
      "id": 41,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut"
      },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT event_type, COUNT(*) as count FROM events GROUP BY event_type ORDER BY count DESC;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Event Type Breakdown",
      "type": "piechart"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 31 },
      "id": 42,
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) as value FROM events WHERE event_type='delivery_failed';",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Delivery Failures",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 31 },
      "id": 43,
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT COUNT(*) as value FROM events WHERE event_type='task_escalated';",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Escalations",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 500,
      "title": "Task Lifecycle",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "unit": "h"
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 40 },
      "id": 50,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT ROUND(AVG(cycle_time_hours), 1) as value FROM task_cycle WHERE completed_at IS NOT NULL AND cycle_time_hours IS NOT NULL;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Avg Cycle Time",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" }
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 40 },
      "id": 51,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT SUM(commits) as value FROM daily_stats;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Total Commits",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "semi-dark-green", "mode": "fixed" }
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 40 },
      "id": 52,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT SUM(insertions) - SUM(deletions) as value FROM daily_stats;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Net Lines Changed",
      "type": "stat"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Created" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Done" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Open" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }, { "id": "custom.fillOpacity", "value": 20 }] }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 40 },
      "id": 53,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT CAST((julianday(date) - 2440587.5) * 86400000 AS INTEGER) as time, total_created as 'Created', total_done as 'Done', total_open as 'Open' FROM burndown ORDER BY date;",
          "queryType": "table",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "title": "Burndown",
      "type": "timeseries"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Insertions" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Deletions" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Commits" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 45 },
      "id": 54,
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT CAST((julianday(date) - 2440587.5) * 86400000 AS INTEGER) as time, commits as 'Commits', insertions as 'Insertions', deletions as 'Deletions' FROM daily_stats WHERE commits > 0 ORDER BY date;",
          "queryType": "table",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "title": "Commits & Code Volume",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "id": 600,
      "title": "Recent Activity",
      "type": "row"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "id": 60,
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT datetime(timestamp, 'unixepoch', 'localtime') as time, event_type, json_extract(payload, '$.from') as sender, json_extract(payload, '$.to') as receiver FROM events ORDER BY timestamp DESC LIMIT 50;",
          "queryType": "table",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "title": "Last 50 Events",
      "type": "table"
    },
    {
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "id": 61,
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "uid": "${datasource}" },
          "rawSql": "SELECT task_id as 'Task', claimed_by as 'Engineer', ROUND(cycle_time_hours, 1) as 'Cycle (h)', ROUND(lead_time_hours, 1) as 'Lead (h)', datetime(completed_at, 'unixepoch', 'localtime') as 'Completed' FROM task_cycle WHERE completed_at IS NOT NULL ORDER BY completed_at DESC LIMIT 25;",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "title": "Recent Completions",
      "type": "table"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["batty", "telemetry", "agents"],
  "templating": {
    "list": [
      {
        "current": { "text": "", "value": "" },
        "description": "SQLite datasource for this project's telemetry",
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "frser-sqlite-datasource",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": { "refresh_intervals": ["5m", "15m", "30m", "1h"] },
  "timezone": "browser",
  "title": "Batty — Project Dashboard",
  "uid": "batty-project",
  "version": 1,
  "alerts": [
    {
      "name": "Agent Stall",
      "condition": "query",
      "frequency": "5m",
      "query": "SELECT COUNT(*) as stalled FROM events WHERE event_type='daemon_heartbeat' AND timestamp > strftime('%s','now') - 600 HAVING COUNT(*) = 0;",
      "message": "No heartbeat received in the last 10 minutes — agent may be stalled"
    },
    {
      "name": "Delivery Failure Spike",
      "condition": "query",
      "frequency": "5m",
      "query": "SELECT COUNT(*) as failures FROM events WHERE event_type='delivery_failed' AND timestamp > strftime('%s','now') - 900 HAVING COUNT(*) > 5;",
      "message": "More than 5 delivery failures in the last 15 minutes"
    },
    {
      "name": "Pipeline Starvation",
      "condition": "query",
      "frequency": "10m",
      "query": "SELECT COUNT(*) as idle FROM events WHERE event_type='task_assigned' AND timestamp > strftime('%s','now') - 1800 HAVING COUNT(*) = 0;",
      "message": "No tasks assigned in the last 30 minutes — pipeline may be starved"
    },
    {
      "name": "High Failure Rate",
      "condition": "query",
      "frequency": "10m",
      "query": "SELECT ROUND(100.0 * CAST((SELECT COUNT(*) FROM events WHERE event_type='delivery_failed' AND timestamp > strftime('%s','now') - 3600) AS REAL) / MAX(1, (SELECT COUNT(*) FROM events WHERE event_type='message_routed' AND timestamp > strftime('%s','now') - 3600)), 1) as failure_pct HAVING failure_pct > 10;",
      "message": "Delivery failure rate exceeds 10% in the last hour"
    },
